rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == 'amrzikas20@gmail.com';
    }

    // --- Validation Blueprints ---
    function isValidCart(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.items is list 
        && data.items.size() <= 100;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.items is list && data.items.size() <= 100
        && data.subtotal is number && data.subtotal >= 0
        && data.discount is number && data.discount >= 0
        && data.total is number && data.total >= 0
        && data.customerInfo is map
        && data.customerInfo.fullName is string && data.customerInfo.fullName.size() <= 150
        && data.customerInfo.email is string && data.customerInfo.email.size() <= 150
        && data.shippingStatus is string && (data.shippingStatus == 'placed' || data.shippingStatus == 'processing' || data.shippingStatus == 'shipped' || data.shippingStatus == 'delivered' || data.shippingStatus == 'rejected')
        && data.date is string && data.date.size() <= 50
        && data.trackingNumber is string && data.trackingNumber.size() <= 100;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128
        && data.productId is string && data.productId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 150
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 5000
        && data.date is string && data.date.size() <= 50;
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.nameAr is string && data.nameAr.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() > 0
        && data.image is string && data.image.size() <= 2000
        && data.stock is number && data.stock >= 0;
    }

    function isValidGateway(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.nameAr is string && data.nameAr.size() <= 100
        && data.status is string && (data.status == 'active' || data.status == 'inactive');
    }

    function isValidShippingPlan(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.nameAr is string && data.nameAr.size() <= 100
        && data.cost is number && data.cost >= 0
        && data.deliveryTime is string && data.deliveryTime.size() <= 100
        && data.status is string && (data.status == 'active' || data.status == 'inactive');
    }

    function isValidSettings(data) {
      return data.storeName is string && data.storeName.size() <= 200
        && data.storeNameAr is string && data.storeNameAr.size() <= 200
        && data.tagline is string && data.tagline.size() <= 500
        && data.taglineAr is string && data.taglineAr.size() <= 500
        && data.currency is string && data.currency.size() <= 10
        && data.vatPercent is number && data.vatPercent >= 0 && data.vatPercent <= 100
        && data.supportEmail is string && data.supportEmail.size() <= 200
        && data.supportPhone is string && data.supportPhone.size() <= 100
        && data.heroTitle is string && data.heroTitle.size() <= 500
        && data.heroTitleAr is string && data.heroTitleAr.size() <= 500
        && data.heroSubtitle is string && data.heroSubtitle.size() <= 2000
        && data.heroSubtitleAr is string && data.heroSubtitleAr.size() <= 2000
        && data.heroBg is string && data.heroBg.size() <= 2000
        && data.maintenanceMode is bool;
    }

    // --- MATCH RULES ---

    // Shopping Carts collection per user
    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidCart(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // Customer Orders collection
    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()))
        || (!isSignedIn() && resource.data.userId == 'guest');
      
      allow create: if (
          (isSignedIn() && request.resource.data.userId == request.auth.uid) ||
          (!isSignedIn() && request.resource.data.userId == 'guest')
        )
        && isValidId(orderId);
        
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if isVerified() 
        && (request.resource.data.userId == request.auth.uid || isAdmin())
        && isValidReview(request.resource.data)
        && isValidId(reviewId);

      allow update: if isVerified()
        && (resource.data.userId == request.auth.uid || isAdmin())
        && (request.resource.data.userId == resource.data.userId)
        && isValidReview(request.resource.data);

      allow delete: if isVerified()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- PRODUCTS (مع تحسينات منع التكرار) ---
    match /products/{productId} {
      allow read: if true;
      
      // منع إنشاء منتج بنفس المعرف إذا كان موجوداً مسبقاً
      allow create: if isAdmin() 
        && isValidProduct(request.resource.data) 
        && isValidId(productId)
        && !exists(/databases/$(database)/documents/products/$(productId));
      
      // منع التحديث إذا كان المعرف غير موجود (للتأكد من عدم إنشاء جديد عن طريق الخطأ)
      allow update: if (isAdmin() 
        && isValidProduct(request.resource.data)
        && exists(/databases/$(database)/documents/products/$(productId)))
        || (
          // Customer/Guest stock level reduction during checkout
          request.resource.data.stock is number
          && request.resource.data.stock >= 0
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
          && request.resource.data.stock < resource.data.stock
        );
      
      allow delete: if isAdmin();
    }

    // --- CATEGORIES (مع تحسينات منع التكرار) ---
    match /categories/{categoryId} {
      allow read: if true;
      
      // منع إنشاء فئة بنفس المعرف إذا كانت موجودة مسبقاً
      allow create: if isAdmin() 
        && isValidId(categoryId)
        && !exists(/databases/$(database)/documents/categories/$(categoryId));
      
      // منع التحديث إذا كانت غير موجودة
      allow update: if isAdmin() 
        && isValidId(categoryId)
        && exists(/databases/$(database)/documents/categories/$(categoryId));
      
      allow delete: if isAdmin();
    }

    // Payment Gateways collection
    match /gateways/{gatewayId} {
      allow read: if true;
      
      allow create: if isAdmin() 
        && isValidGateway(request.resource.data) 
        && isValidId(gatewayId)
        && !exists(/databases/$(database)/documents/gateways/$(gatewayId));
      
      allow update: if isAdmin() 
        && isValidGateway(request.resource.data) 
        && isValidId(gatewayId)
        && exists(/databases/$(database)/documents/gateways/$(gatewayId));
      
      allow delete: if isAdmin();
    }

    // Shipping Plans collection
    match /shippingPlans/{planId} {
      allow read: if true;
      
      allow create: if isAdmin() 
        && isValidShippingPlan(request.resource.data) 
        && isValidId(planId)
        && !exists(/databases/$(database)/documents/shippingPlans/$(planId));
      
      allow update: if isAdmin() 
        && isValidShippingPlan(request.resource.data) 
        && isValidId(planId)
        && exists(/databases/$(database)/documents/shippingPlans/$(planId));
      
      allow delete: if isAdmin();
    }

    // Site settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSettings(request.resource.data) && isValidId(settingId);
      allow delete: if false;
    }

    // --- NEW: سجل العمليات (Audit Log) لمنع التكرار ---
    // هذه المجموعة لتسجيل محاولات الإضافة المتكررة
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}